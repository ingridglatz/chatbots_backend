# ──────────────────────────────────────────
# SERVIDOR
# ──────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ──────────────────────────────────────────
# BANCO DE DADOS (PostgreSQL)
# ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/chatbots_db

# ──────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────
# AUTENTICAÇÃO JWT
# ──────────────────────────────────────────
JWT_SECRET=sua_chave_secreta_super_longa_e_aleatoria_aqui
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────
# ANTHROPIC (Claude AI)
# ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────
# STRIPE (Pagamentos)
# ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ASAAS (Alternativa BR)
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# ──────────────────────────────────────────
# WHATSAPP (Evolution API)
# ──────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_da_evolution_api

# ──────────────────────────────────────────
# CORS — domínios permitidos (separados por vírgula)
# ──────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://seuapp.com

# ──────────────────────────────────────────
# RATE LIMITING (por tenant, por minuto)
# ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ──────────────────────────────────────────
# LOGS
# ──────────────────────────────────────────
LOG_LEVEL=debug
